    51 00000005 01                          db 1                    ; EI_DATA  = LSB
    52 00000006 01                          db 1                    ; EI_VERSION
    53 00000007 00                          db 0                    ; EI_OSABI
    54 00000008 00                          db 0                    ; EI_ABIVERSION
    55 00000009 00<rep 7h>                  times 7 db 0            ; EI_PAD
    56 00000010 0200                        dw 2                    ; e_type = ET_EXEC
    57 00000012 3E00                        dw 0x3E                 ; e_machine = EM_X86_64
    58 00000014 01000000                    dd 1                    ; e_version = EV_CURRENT
