     1
     2                                  %macro define_libs 1-*
     3                                      ; We'll store the number of parameters in a variable
     4                                      ; and define library_nameX for each parameter.
     5
     6                                      %assign i 1
     7                                      %rep %0
     8                                          ; %1 is the first parameter of the current iteration
     9                                          ; library_name<i> is a text definition that expands to the string
    10                                          %xdefine library_name%[i] %1
    11
    12                                          ; Move on to the next parameter
    13                                          %rotate 1
    14                                          %assign i i+1
    15                                      %endrep
    16
    17                                      ; i-1 is how many parameters we processed
    18                                      %assign library_count i-1
    19                                  %endmacro
    20
    21                                  %macro libraries_strings 0
    22                                      %assign i 1
    23                                      %rep library_count
    24                                          str_library_name%[i]: db library_name%[i], 0
    25                                          %assign i i+1
    26                                      %endrep
    27                                  %endmacro
    28
    29                                  %macro libraries_needed 0
    30                                      %assign i 1
    31                                      %rep library_count
    32                                          dq 1, str_library_name%[i] - dynstr
    33                                          %assign i i+1
    34                                      %endrep
    35                                  %endmacro
    36
