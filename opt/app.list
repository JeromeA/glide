    43
    44                                  ; =============================================================================
    45                                  ; ELF Header
    46                                  ; =============================================================================
    47
    48                                      ; -- e_ident (16 bytes) --
    49 00000000 7F454C46                    db 0x7F, "ELF"          ; ELF magic
    50 00000004 02                          db 2                    ; EI_CLASS = 64-bit
    51 00000005 01                          db 1                    ; EI_DATA  = LSB
    52 00000006 01                          db 1                    ; EI_VERSION
    53 00000007 00                          db 0                    ; EI_OSABI
    54 00000008 00                          db 0                    ; EI_ABIVERSION
    55 00000009 00<rep 7h>                  times 7 db 0            ; EI_PAD
    56 00000010 0200                        dw 2                    ; e_type = ET_EXEC
    57 00000012 3E00                        dw 0x3E                 ; e_machine = EM_X86_64
    58 00000014 01000000                    dd 1                    ; e_version = EV_CURRENT
    59 00000018 [A001400000000000]          dq BASE_ADDR + start    ; e_entry
    60 00000020 [4000000000000000]          dq program_headers      ; e_phoff
    61 00000028 0000000000000000            dq 0
    62 00000030 00000000                    dd 0                    ; e_flags
    63 00000034 [4000]                      dw ElfHeader_end        ; e_ehsize
    64 00000036 3800                        dw 56                   ; e_phentsize for Elf64_Phdr
    65 00000038 0300                        dw 3                    ; e_phnum (PT_LOAD + PT_DYNAMIC + PT_INTERP)
    66                                  ; Nothing seems to happen when the following fields are missing are overwritten.
    67 0000003A 0000                        dw 0                    ; e_shentsize
    68 0000003C 0000                        dw 0                    ; e_shnum
    69 0000003E 0000                        dw 0                    ; e_shstrndx = index of .shstrtab (required by gdb)
    70
    71                                  ElfHeader_end:
    72
