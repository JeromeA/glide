   102 000000B8 [E800000000000000]          dq interp_section    ; p_offset = file offset of the .interp bytes
   103 000000C0 [E800400000000000]          dq BASE_ADDR + interp_section  ; p_vaddr
   104 000000C8 [E800400000000000]          dq BASE_ADDR + interp_section  ; p_paddr
   105 000000D0 1C00000000000000            dq (interp_section_end - interp_section)
   106 000000D8 1C00000000000000            dq (interp_section_end - interp_section)
   107 000000E0 0100000000000000            dq 1                 ; p_align
