    81 00000044 07000000                    dd 7             ; p_flags = PF_R + PF_W + PF_X
    82 00000048 0000000000000000            dq 0             ; p_offset
    83 00000050 0000400000000000            dq BASE_ADDR     ; p_vaddr
    84 00000058 0000400000000000            dq BASE_ADDR     ; p_paddr
    85 00000060 [7472000000000000]          dq eof
    86 00000068 [6878000000000000]          dq eof + bss_size
    87 00000070 0010000000000000            dq 0x1000        ; p_align
    88
    89                                  ph_dynamic:
    90 00000078 02000000                    dd 2             ; p_type = PT_DYNAMIC
    91 0000007C 06000000                    dd 6             ; p_flags = PF_R + PF_W
    92 00000080 [0801000000000000]          dq dynamic_section
    93 00000088 [0801400000000000]          dq BASE_ADDR + dynamic_section
    94 00000090 [0801400000000000]          dq BASE_ADDR + dynamic_section
    95 00000098 9800000000000000            dq (dynamic_section_end - dynamic_section)
    96 000000A0 9800000000000000            dq (dynamic_section_end - dynamic_section)
    97 000000A8 0800000000000000            dq 8
